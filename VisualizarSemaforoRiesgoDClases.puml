@startuml "Diagrama de Clases - Semáforo de Riesgo"

' Estilo profesional y limpio
skinparam class {
    BackgroundColor #F3F9FF
    BorderColor #2B88D9
    ArrowColor #2B88D9
}
skinparam enum {
    BackgroundColor #FFF3CD
    BorderColor #FFC107
}

class User {
    - id: String
    - name: String
}

class SearchController {
    + searchAlternatives(amount: double, term: int): List<FinancialInstitution>
}

class RiskService {
    + getTrafficLightStatus(institutionId: String): TrafficLightStatus
    + calculateTrafficLightStatusFromSbs(sbsRating: String): TrafficLightStatus
}

class FinancialInstitution {
    - id: String
    - name: String
    - offeredRate: float
    - sbsRating: String
}

enum TrafficLightStatus {
    GREEN
    YELLOW
    RED
}

User --> SearchController : interacts
SearchController ..> RiskService : consults
RiskService ..> FinancialInstitution : gets data from
RiskService ..> TrafficLightStatus : calculates

@enduml
