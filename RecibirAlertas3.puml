@startuml c3_diagrama_secuencia

skinparam sequenceArrowThickness 1.5
skinparam sequenceParticipantBackgroundColor #FAFAFA
skinparam sequenceParticipantBorderColor #333333
skinparam sequenceLifeLineBorderColor #333333
skinparam sequenceArrowColor #333333
skinparam noteBorderColor #333333

actor "User" as User
participant "UI_Alerts" as UI
participant "AlertService" as Service
participant "ChangeMonitor" as Monitor
database "FinancialDatabase" as BD

== Initial Alert Configuration ==

User -> UI : configureAlert(institution, threshold)
UI -> Service : registerConfiguration(userId, institutionId, threshold)
Service -> BD : saveConfiguration(config)
BD --> Service : confirmation
Service --> UI : alertConfigured
UI --> User : show message "Alert activated"

== Automatic Change Detection ==

Monitor -> BD : queryFinancialInstitutions()
BD --> Monitor : List<FinancialInstitution>
Monitor -> Monitor : compareValues(previous, current)

alt [Change detected in rate or risk]
  Monitor -> BD : registerAlert(type, previousValue, newValue)
  BD --> Monitor : alertId
  Monitor -> Service : notifyAffectedUsers(alertId)
  Service -> BD : getUsersWithConfiguration(institutionId)
  BD --> Service : List<User>
  Service --> UI : sendNotification(user, alert)
  UI --> User : show alert on screen
else [No relevant changes]
  Monitor -> Monitor : continue monitoring
end

== Alert Visualization ==

User -> UI : viewAlertDetail(alertId)
UI -> Service : getAlertDetail(alertId)
Service -> BD : findAlert(alertId)
BD --> Service : Alert
Service -> Service : alert.markAsRead()
Service --> UI : alertDetail
UI --> User : show previousValue, newValue and institution

@enduml
