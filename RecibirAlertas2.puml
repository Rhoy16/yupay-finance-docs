@startuml c2_diagrama_clases

skinparam classAttributeIconSize 0
skinparam class {
  BackgroundColor #FAFAFA
  BorderColor #333333
  ArrowColor #333333
}

enum TipoAlerta {
  CAMBIO_TASA
  CAMBIO_RIESGO
}

enum EstadoAlerta {
  PENDIENTE
  ENVIADA
  LEIDA
}

enum TipoSuscripcion {
  BASICO
  PRO
}

class Usuario {
  - id : int
  - nombre : String
  - email : String
  - suscripcion : TipoSuscripcion
  + configurarAlerta(entidad: EntidadFinanciera, umbral: double) : void
  + verAlertas() : List~Alerta~
}

class ConfiguracionAlerta {
  - id : int
  - umbralTasa : double
  - activa : boolean
  + activar() : void
  + desactivar() : void
  + validar() : boolean
}

class Alerta {
  - id : int
  - tipo : TipoAlerta
  - mensaje : String
  - fechaGenerada : date
  - estado : EstadoAlerta
  - valorAnterior : double
  - valorNuevo : double
  + generarMensaje() : String
  + marcarLeida() : void
}

class EntidadFinanciera {
  - id : int
  - nombre : String
  - tipo : String
  - tasaActual : double
  - nivelRiesgo : String
  + getTasa() : double
  + getNivelRiesgo() : String
}

class MonitorCambios {
  + detectarCambios(entidades: List~EntidadFinanciera~) : List~Alerta~
  + compararValores(anterior: double, nuevo: double) : boolean
  + notificarUsuarios(alerta: Alerta) : void
}

Usuario "1" --> "0..*" ConfiguracionAlerta : configura
ConfiguracionAlerta "1" --> "1" EntidadFinanciera : monitorea
MonitorCambios "1" --> "0..*" EntidadFinanciera : consulta
MonitorCambios "1" --> "0..*" Alerta : genera
Alerta "0..*" --> "1" Usuario : notifica

@enduml
