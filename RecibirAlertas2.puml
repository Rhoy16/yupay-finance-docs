@startuml c2_diagrama_clases

skinparam classAttributeIconSize 0
skinparam class {
  BackgroundColor #FAFAFA
  BorderColor #333333
  ArrowColor #333333
}

enum AlertType {
  RATE_CHANGE
  RISK_CHANGE
}

enum AlertState {
  PENDING
  SENT
  READ
}

enum SubscriptionType {
  BASIC
  PRO
}

class User {
  - id : int
  - name : String
  - email : String
  - subscription : SubscriptionType
  + configureAlert(institution: FinancialInstitution, threshold: double) : void
  + getAlerts() : List~Alert~
}

class AlertConfiguration {
  - id : int
  - rateThreshold : double
  - isActive : boolean
  + activate() : void
  + deactivate() : void
  + validate() : boolean
}

class Alert {
  - id : int
  - type : AlertType
  - message : String
  - generatedDate : Date
  - state : AlertState
  - previousValue : double
  - newValue : double
  + generateMessage() : String
  + markAsRead() : void
}

class FinancialInstitution {
  - id : int
  - name : String
  - type : String
  - currentRate : double
  - riskLevel : String
  + getInterestRate() : double
  + getRiskLevel() : String
}

class ChangeMonitor {
  + detectChanges(institutions: List~FinancialInstitution~) : List~Alert~
  + compareValues(previous: double, current: double) : boolean
  + notifyUsers(alert: Alert) : void
}

User "1" --> "0..*" AlertConfiguration : configures
AlertConfiguration "1" --> "1" FinancialInstitution : monitors
ChangeMonitor "1" --> "0..*" FinancialInstitution : queries
ChangeMonitor "1" --> "0..*" Alert : generates
Alert "0..*" --> "1" User : notifies

@enduml
