@startuml "Secuencia - Visualizar Semáforo de Riesgo"

autonumber
skinparam BoxPadding 10
skinparam ParticipantPadding 10

' Estilo profesional y limpio
skinparam actorStyle awesome
skinparam sequence {
    LifeLineBorderColor #2B88D9
    LifeLineBackgroundColor #F3F9FF
    ParticipantBorderColor #2B88D9
    ParticipantBackgroundColor #F3F9FF
    BoxBorderColor #2B88D9
    BoxBackgroundColor #F8F9FA
}

actor User as usr
boundary UI_Comparator as ui
control RiskService as srv
database FinancialDatabase as db

usr -> ui : Views the list of financial institutions
activate ui

loop For each rendered institution
    ui -> srv : getTrafficLightStatus(institutionId)
    activate srv
    
    srv -> db : querySbsRating(institutionId)
    activate db
    db --> srv : sbsRating (e.g. "A", "C", "E")
    deactivate db
    
    srv -> srv : calculateTrafficLightStatusFromSbs(sbsRating)
    note right: Internal Logic:\n- A/B -> GREEN\n- C -> YELLOW\n- D/E -> RED
    
    srv --> ui : TrafficLightStatus (GREEN | YELLOW | RED)
    deactivate srv
    
    ui -> ui : showTrafficLightIcon(color)
end

ui --> usr : Visualizes traffic lights next to each institution
deactivate ui

@enduml
