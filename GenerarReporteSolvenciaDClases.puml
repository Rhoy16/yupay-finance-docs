@startuml "Diagrama de Clases - Reporte de Solvencia"

' Estilo profesional y limpio
skinparam class {
    BackgroundColor #F3F9FF
    BorderColor #2B88D9
    ArrowColor #2B88D9
}

class User {
    - id: String
    - name: String
}

class ReportController {
    + requestReport(institutionId: int): SolvencyReport
    + requestPdfDownload(institutionId: int): File
}

class SolvencyService {
    + createReport(institutionId: int): SolvencyReport
    + exportPdf(report: SolvencyReport): File
}

class FinancialInstitution {
    - id: int
    - name: String
    - globalCapitalRatio: float
    - equity: float
}

class SolvencyReport {
    - generationDate: Date
    - riskSummary: String
    - format: String
}

User --> ReportController : requests
ReportController ..> SolvencyService : delegates
SolvencyService ..> FinancialInstitution : queries data from
SolvencyService ..> SolvencyReport : generates

@enduml
