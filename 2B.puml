@startuml

class User {
    - userId: int
    - name: String
    - email: String
    + saveFavoriteSimulation(sim: Simulation): void
}

class YupayFinanceApp {
    - appId: int
    + displaySimulator(): void
    + pressSave(): void
}

class Simulation {
    - simulationId: int
    - amount: double
    - currency: String
    - dueDate: Date
    - calculatedYield: double
    + calculateYield(): double
}

class FinancialInstitution {
    - institutionName: String
    - riskLevel: String
    + getFinancialData(): void
}

User "1" --> "1" YupayFinanceApp
YupayFinanceApp "1" --> "*" Simulation : manages
User "1" --> "*" Simulation : storesFavoriteSimulations
Simulation "*" --> "1" FinancialInstitution : evaluates

@enduml