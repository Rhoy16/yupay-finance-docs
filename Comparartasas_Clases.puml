@startuml "Clases - Comparar Tasas de Entidades Financieras"

class User {
    - id: int
    - name: String
    - email: String
    - subscription: SubscriptionType
    --
    + inputParameters(amount: double, term: int, currency: CurrencyType): void
    + applyFilter(filter: Filter): void
    + getResultsList(): List~SearchResult~
}

class SearchParameter {
    - amount: double
    - term: int
    - currency: CurrencyType
    --
    + validate(): boolean
}

class FinancialInstitution {
    - id: int
    - name: String
    - type: InstitutionType
    - interestRate: double
    --
    + getInterestRate(): double
}

class SearchResult {
    - institution: FinancialInstitution
    - interestRate: double
    - type: InstitutionType
    --
    + getDetail(): String
}

class Filter {
    - institutionType: InstitutionType
    --
    + apply(list: List~FinancialInstitution~): List~FinancialInstitution~
}

enum CurrencyType {
    PEN
    USD
}

enum InstitutionType {
    BANK
    SAVINGS_BANK
    COOPERATIVE
}

enum SubscriptionType {
    BASIC
    PRO
}

User "1" -down-> "1" SearchParameter : search
User "1" -right-> "0..1" Filter : filter
User -right-> SubscriptionType
SearchParameter "1" -down-> "1..*" SearchResult : generates
SearchResult "1" -right-> "1" FinancialInstitution : references
SearchParameter -right-> CurrencyType
Filter -down-> InstitutionType
FinancialInstitution -down-> InstitutionType

@enduml