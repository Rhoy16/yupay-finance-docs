@startuml "Diagrama de Componentes - Yupay Finance API"
skinparam componentStyle uml2
skinparam linetype ortho
left to right direction

interface "API Contract" as Contract

component "Yupay Finance RESTful API" as API {
  
  component "Identity & Access Bounded Context" as BC_IdentityAccess {
    component "Interface Layer" as IA_Interface
    component "Application Layer" as IA_Application
    component "Domain Layer" as IA_Domain
    component "Infrastructure Layer" as IA_Infrastructure
  }

  component "Simulation Bounded Context" as BC_Simulation {
    component "Interface Layer" as S_Interface
    component "Application Layer" as S_Application
    component "Domain Layer" as S_Domain
    component "Infrastructure Layer" as S_Infrastructure
  }

  component "Catalog & Risk Bounded Context" as BC_CatalogRisk {
    component "Interface Layer" as CR_Interface
    component "Application Layer" as CR_Application
    component "Domain Layer" as CR_Domain
    component "Infrastructure Layer" as CR_Infrastructure
  }

  component "Billing & Subscriptions Bounded Context" as BC_Billing {
    component "Interface Layer" as B_Interface
    component "Application Layer" as B_Application
    component "Domain Layer" as B_Domain
    component "Infrastructure Layer" as B_Infrastructure
  }

  component "Monitoring & Alerts Bounded Context" as BC_MonitoringAlerts {
    component "Interface Layer" as MA_Interface
    component "Application Layer" as MA_Application
    component "Domain Layer" as MA_Domain
    component "Infrastructure Layer" as MA_Infrastructure
  }
}

database "Relational Database\n(PostgreSQL)" as RelationalDatabase <<external>>
component "Payment Gateway API\n(Stripe / Niubiz)" as PaymentGateway <<external>>
component "Email Service API\n(SendGrid / AWS SES)" as EmailService <<external>>

' Conexión del API general con el exterior
API --> Contract

' Conexiones internas Clean Architecture: Identity
IA_Interface ..> IA_Application
IA_Application ..> IA_Domain
IA_Application ..> IA_Infrastructure

' Conexiones internas Clean Architecture: Simulation
S_Interface ..> S_Application
S_Application ..> S_Domain
S_Application ..> S_Infrastructure

' Conexiones internas Clean Architecture: Catalog & Risk[cite: 12]
CR_Interface ..> CR_Application
CR_Application ..> CR_Domain
CR_Application ..> CR_Infrastructure

' Conexiones internas Clean Architecture: Billing[cite: 12]
B_Interface ..> B_Application
B_Application ..> B_Domain
B_Application ..> B_Infrastructure

' Conexiones internas Clean Architecture: Monitoring[cite: 12]
MA_Interface ..> MA_Application
MA_Application ..> MA_Domain
MA_Application ..> MA_Infrastructure

' Conexiones hacia la Infraestructura Externa (Base de Datos)[cite: 12]
IA_Infrastructure ..> RelationalDatabase
S_Infrastructure ..> RelationalDatabase
CR_Infrastructure ..> RelationalDatabase
B_Infrastructure ..> RelationalDatabase
MA_Infrastructure ..> RelationalDatabase

' Conexiones hacia Servicios de Terceros
B_Infrastructure ..> PaymentGateway
MA_Infrastructure ..> EmailService

@enduml