@startuml "Casos de Uso - Consultar Glosario Financiero"

' Estilo profesional y limpio
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam usecase {
    BackgroundColor #F3F9FF
    BorderColor #2B88D9
    ArrowColor #2B88D9
    ActorBorderColor #2B88D9
    ActorBackgroundColor #F3F9FF
}

actor "User" as user

package "Yupay Finance" {
    usecase "Consult glossary" as UC_glosario
    usecase "Search specific term" as UC_buscar
    usecase "Suggest new term" as UC_sugerir
}

user --> UC_glosario

UC_glosario ..> UC_buscar : <<include>>
UC_sugerir ..> UC_glosario : <<extend>>

@enduml
