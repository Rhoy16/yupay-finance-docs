@startuml "Diagrama de Clases - Glosario Financiero"

' Estilo profesional y limpio
skinparam class {
    BackgroundColor #F3F9FF
    BorderColor #2B88D9
    ArrowColor #2B88D9
}

class User {
    - id: int
    - name: String
}

class GlossaryController {
    + searchTerm(word: String): List<FinancialTerm>
    + listPopularTerms(): List<FinancialTerm>
}

class GlossaryService {
    + searchTerm(word: String): List<FinancialTerm>
    + getPopularTerms(): List<FinancialTerm>
}

class FinancialTerm {
    - id: int
    - termName: String
    - technicalDefinition: String
    - simpleDefinition: String
    - practicalExample: String
}

User --> GlossaryController : consults
GlossaryController ..> GlossaryService : delegates
GlossaryService ..> FinancialTerm : searches and returns

@enduml
