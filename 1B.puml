@startuml

class User {
    - id: int
    - name: String
    - email: String
    + inputParameters(amount: double, term: int, currency: CurrencyType): void
    + applyFilter(filter: Filter): void
    + getResultsList(): List<SearchResult>
}

class Filter {
    - institutionType: InstitutionType
    - riskLevel: String
    + apply(list: List<FinancialInstitution>): List<FinancialInstitution>
}

class SearchParameter {
    - amount: double
    - term: int
    - currency: CurrencyType
    + validate(): boolean
}

class SearchResult {
    - institution: FinancialInstitution
    - interestRate: double
    - type: InstitutionType
    + getDetail(): String
}

class FinancialInstitution {
    - id: int
    - name: String
    - type: InstitutionType
    - interestRate: double
    + getInterestRate(): double
}

enum InstitutionType {
    BANK
    SAVINGS_BANK
    COOPERATIVE
}

enum CurrencyType {
    PEN
    USD
}

User "1" --> "0..1" Filter : filter
User "1" --> "1" SearchParameter : search
SearchParameter "1" --> "1..*" SearchResult : generates
SearchResult "1" --> "1" FinancialInstitution : references
Filter --> InstitutionType
FinancialInstitution --> InstitutionType

@enduml