@startuml "Comparar Tasas de Entidades Financieras"
left to right direction

skinparam usecase {
    BackgroundColor #FFF9C4
    BorderColor #7A1631
    StereotypeFontColor #2E7D32
}
skinparam actor {
    BackgroundColor #FFF9C4
    BorderColor #7A1631
}
skinparam Arrow {
    Color #7A1631
}
skinparam linetype ortho

actor "User" as Usuario
actor "Financial Database" as BD

rectangle "Yupay Finance" {
    usecase "Input amount,\nterm and currency" as UC1
    usecase "Query financial\ninstitutions" as UC2
    usecase "View list\nsorted by rate" as UC3
    usecase "Filter results" as UC4
}

Usuario --> UC1
Usuario --> UC3
Usuario --> UC4

UC1 .right.> UC2 : <<include>>
UC2 .right.> UC3 : <<include>>
UC4 .up.> UC3 : <<extend>>

BD -up-> UC2

@enduml