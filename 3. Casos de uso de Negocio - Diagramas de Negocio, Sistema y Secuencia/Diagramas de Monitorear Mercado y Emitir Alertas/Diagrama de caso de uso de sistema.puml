@startuml "Casos de Uso de Sistema: Monitorear Mercado y Emitir Alertas"
left to right direction
skinparam usecase {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}
skinparam actor {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}
skinparam Arrow {
  Color #7A1631
}

' Actores
actor "Motor Yupay\n(Proceso Automático)" as Motor
actor "Usuario Pro" as UsuarioPro
actor "Servicio de Correo" as Correo

' Límite del Sistema
rectangle "Sistema Yupay Finance - Motor de Alertas Críticas" {
  usecase "Monitorear Fluctuaciones del Mercado" as UC1
  usecase "Generar Alerta Crítica de Riesgo" as UC2
  usecase "Desplegar Notificación Visual (Campana)" as UC3
  usecase "Enviar Correo de Emergencia" as UC4
  usecase "Consultar Panel de Alertas" as UC5
}

' Relaciones del Actor Automático
Motor -- UC1

' Relaciones Lógicas Internas
UC1 .> UC2 : <<extend>>
UC2 ..> UC3 : <<include>>
UC2 ..> UC4 : <<include>>

' Relaciones con Actores Externos
UC4 -- Correo
UsuarioPro -- UC5

@enduml