@startuml "Business Case: Monitorear Mercado y Emitir Alertas"

' Trabajadores internos del negocio
actor/ "Motor Yupay (Sistema)" <<Business Worker>> as Motor

' Límite del Modelo de Negocio
rectangle "Modelo de Casos de Uso del Negocio - Yupay Finance" {
  usecase/ "Monitorear Mercado \ny Emitir Alertas" as BUC5
  usecase/ "Recolectar y Actualizar \nDatos Financieros" as BUC6
}

' Relaciones
Motor --> BUC5
BUC5 ..> BUC6 : <<include>>

' Estética 
skinparam usecase {
  BackgroundColor #C7F4FF
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}
skinparam actor {
  BackgroundColor #C7F4FF
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}
skinparam Arrow {
  Color #7A1631
}
@enduml