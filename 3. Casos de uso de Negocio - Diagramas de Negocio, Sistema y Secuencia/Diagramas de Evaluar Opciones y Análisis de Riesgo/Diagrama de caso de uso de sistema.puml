@startuml "Casos de Uso de Sistema: Análisis de Opciones y Riesgo"
left to right direction
skinparam usecase {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}
skinparam actor {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}
skinparam Arrow {
  Color #7A1631
}

' Actores
actor "Usuario Básico" as Usuario
actor "Usuario Pro" as UsuarioPro

' Herencia de actores
Usuario <|-- UsuarioPro

' Límite del Sistema
rectangle "Sistema Yupay Finance - Análisis y Riesgo" {
  usecase "Visualizar Tabla de Resultados" as UC1
  usecase "Consultar Glosario de Términos" as UC2
  usecase "Ver Semáforo de Riesgo" as UC3
  usecase "Consultar Informe de Economista" as UC4
  usecase "Guardar Simulación Financiera" as UC5
  usecase "Calcular Rentabilidad y Validar FSD" as UC6
}

' Relaciones del Usuario Básico (y heredadas por el Pro)
Usuario -- UC1
Usuario -- UC2
Usuario -- UC3

' Relaciones exclusivas del Usuario Pro
UsuarioPro -- UC4
UsuarioPro -- UC5

' Relación de Inclusión (Procesamiento interno del sistema)
UC1 ..> UC6 : <<include>>

@enduml