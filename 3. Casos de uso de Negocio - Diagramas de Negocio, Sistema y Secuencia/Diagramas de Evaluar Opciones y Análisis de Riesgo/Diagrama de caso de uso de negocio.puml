@startuml "Business Case: Evaluar Opciones y Análisis de Riesgo"

' Actores externos al negocio 
actor/ "Usuario" <<Business Actor>> as User

' Trabajadores internos del negocio
actor/ "Economista" <<Business Worker>> as Economista

' Límite del Modelo de Negocio
rectangle "Modelo de Casos de Uso del Negocio - Yupay Finance" {
  usecase/ "Evaluar Opciones \ny Análisis de Riesgo" as BUC3
}

' Relaciones
User --> BUC3
Economista --> BUC3

' Estética 
skinparam usecase {
  BackgroundColor #C7F4FF
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}
skinparam actor {
  BackgroundColor #C7F4FF
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}
skinparam Arrow {
  Color #7A1631
}
@enduml