@startuml "Casos de Uso de Sistema: Simular Búsqueda y Rentabilidad"
left to right direction
skinparam usecase {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}
skinparam actor {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}
skinparam Arrow {
  Color #7A1631
}

' Actores
actor "Usuario" as Usuario

' Límite del Sistema
rectangle "Sistema Yupay Finance - Búsqueda y Simulación" {
  usecase "Seleccionar Tipo de Instrumento" as UC1
  usecase "Configurar Parámetros de Búsqueda" as UC2
  usecase "Configurar Cuenta de Ahorros" as UC2A
  usecase "Configurar Depósito a Plazo Fijo" as UC2B
  usecase "Realizar Simulación" as UC3
  usecase "Filtrar Entidades por Restricciones" as UC4
}

' Relaciones del actor
Usuario -- UC1
Usuario -- UC2
Usuario -- UC3

' Relaciones de Extensión (Opciones específicas según el instrumento)
UC2A .> UC2 : <<extend>>
UC2B .> UC2 : <<extend>>

' Relaciones de Inclusión (Procesos obligatorios del sistema)
UC3 ..> UC4 : <<include>>

@enduml