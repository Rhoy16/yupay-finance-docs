@startuml "Casos de Uso de Sistema: Gestión de Acceso y Cuentas"
left to right direction
skinparam usecase {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}
skinparam actor {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}
skinparam Arrow {
  Color #7A1631
}

' Actores
actor "Visitante" as Visitante
actor "Usuario Registrado" as Usuario
actor "Usuario Pro" as UsuarioPro
actor "Servicio de Correo" as Correo

' Herencia: El Usuario Pro puede hacer todo lo del Usuario Registrado
Usuario <|-- UsuarioPro

' Límite del Sistema
rectangle "Sistema Yupay Finance - Módulo de Acceso" {
  usecase "Registrar Nueva Cuenta" as UC1
  usecase "Iniciar Sesión" as UC2
  usecase "Recuperar Contraseña" as UC3
  usecase "Actualizar Datos Personales" as UC4
  usecase "Configurar Preferencias de Notificaciones" as UC5
}

' Relaciones de los actores con los Casos de Uso
Visitante -- UC1
Usuario -- UC2
Usuario -- UC3
Usuario -- UC4
UsuarioPro -- UC5

' Relación con el sistema externo
UC3 -- Correo

@enduml