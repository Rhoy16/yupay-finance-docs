@startuml 1C
autonumber

actor User as usr
boundary UI_Comparator as ui
control RateComparatorService as srv
database FinancialDatabase as db

usr -> ui: inputParameters(amount, term, currency)
activate ui
ui -> srv: searchRates(amount, term, currency)
activate srv

srv -> db: queryFinancialInstitutions(currency, term)
activate db
db --> srv: List<FinancialInstitution>
deactivate db

srv -> srv: sortByRate(institutions)
ui <-- srv: List<SearchResult> sortedResults
deactivate srv

usr <-- ui: displayListSortedByRate

alt User applies filter criteria
    usr -> ui: applyFilter(institutionType, riskLevel)
    ui -> srv: filterInstitutions(filter)
    activate srv
    srv -> srv: apply(filter, institutions)
    ui <-- srv: List<SearchResult> filteredResults
    deactivate srv
    usr <-- ui: displayFilteredList
end
deactivate ui

@enduml