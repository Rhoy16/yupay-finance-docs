@startuml "Secuencia - Consultar Glosario Financiero"

autonumber
skinparam BoxPadding 10
skinparam ParticipantPadding 10

' Estilo profesional y limpio
skinparam actorStyle awesome
skinparam sequence {
    LifeLineBorderColor #2B88D9
    LifeLineBackgroundColor #F3F9FF
    ParticipantBorderColor #2B88D9
    ParticipantBackgroundColor #F3F9FF
    BoxBorderColor #2B88D9
    BoxBackgroundColor #F8F9FA
}

actor User as usr
boundary UI_Glossary as ui
control GlossaryController as ctrl
participant GlossaryService as srv
database GlossaryDatabase as db
entity FinancialTerm as term

== Financial Term Search ==

usr -> ui : Enters word in search bar (e.g. "TREA")
activate ui

ui -> ctrl : searchTerm(word)
activate ctrl

ctrl -> srv : searchTerm(word)
activate srv

srv -> db : SELECT * FROM terms\nWHERE termName LIKE '%word%'
activate db
db --> srv : found records (definition, example)
deactivate db

srv -> term ** : <<create>> FinancialTerm(data)
srv --> ctrl : List<FinancialTerm>
deactivate srv

ctrl --> ui : termsList
deactivate ctrl

ui --> usr : Renders card with:\n• Term Name\n• Simple definition\n• Practical example
deactivate ui

@enduml
