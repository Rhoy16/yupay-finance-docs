@startuml
left to right direction
actor "User" as user

rectangle "Yupay Finance" {
    usecase "Input simulation data" as UC_ingresar
    usecase "Estimate yield and risk" as UC_estimar
    usecase "Save simulation to profile" as UC_guardar
}

user --> UC_ingresar
user --> UC_guardar

UC_ingresar ..> UC_estimar : <<include>>
UC_guardar ..> UC_estimar : <<include>> (requires prior calculation)
@enduml