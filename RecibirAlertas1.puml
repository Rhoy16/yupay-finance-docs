@startuml c1_caso_uso_sistema

skinparam packageStyle rectangle
skinparam usecase {
  BackgroundColor #FAFAFA
  BorderColor #333333
  ArrowColor #333333
  ActorBorderColor #333333
  ActorBackgroundColor #FAFAFA
}

left to right direction

actor "User" as User
actor "Yupay\nSystem" as YupaySystem <<system>>

rectangle "Yupay Finance" {
  usecase "Receive alerts for\nrate or risk changes" as UC_Main
  usecase "Configure\nalert preferences" as UC_Config
  usecase "View alert\ndetails" as UC_Detalle
  usecase "Query changes\nin Database" as UC_Consulta
}

User --> UC_Main
User --> UC_Config
UC_Config .> UC_Main : <<include>>
UC_Main .> UC_Consulta : <<include>>
UC_Main <.. UC_Detalle : <<extend>>
YupaySystem --> UC_Consulta

note right of UC_Main
  Only available for
  users with Pro Plan
end note

@enduml
