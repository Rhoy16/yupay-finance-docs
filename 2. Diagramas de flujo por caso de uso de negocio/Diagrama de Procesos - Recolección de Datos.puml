@startuml "Diagrama de Procesos - Recolección de Datos"
skinparam SwimlaneTitleBackgroundColor #EEE
skinparam ActivityBackgroundColor #FFF9C4
skinparam ActivityBorderColor #7A1631
skinparam Arrow {
  Color #7A1631
}

|Analista de Datos|
start
:Revisa portales oficiales de la\nSBS y Entidades Financieras;
:Extrae tasas de interés vigentes\ny calificaciones de riesgo;

|Sistema Yupay (Panel Admin)|
:El analista ingresa los datos\nrecolectados al sistema;
:Valida el formato de\nlos datos ingresados;

while (¿Los datos tienen el formato correcto?) is (No)
  :Muestra errores de validación;
  |Analista de Datos|
  :Corrige los datos ingresados;
  |Sistema Yupay (Panel Admin)|
endwhile (Sí)

:Actualiza la Base de Datos\nFinanciera;
:Notifica actualización exitosa;

stop
@enduml