@startuml "Secuencia - Comparar Tasas de Entidades Financieras"
autonumber

actor User as usr
boundary UI_Comparator as ui
control RateComparatorService as srv
database FinancialDatabase as db

usr -> ui : inputParameters(amount, term, currency)
activate ui

ui -> srv : searchRates(amount, term, currency)
activate srv

srv -> db : queryFinancialInstitutions(currency, term)
activate db
db --> srv : List<FinancialInstitution>
deactivate db

srv -> srv : sortByRate(institutions)
srv --> ui : List<SearchResult> sortedResults
deactivate srv

ui --> usr : display list sorted by rate
deactivate ui

alt User applies filter
    usr -> ui : applyFilter(institutionType)
    activate ui
    ui -> srv : filterInstitutions(filter)
    activate srv
    srv -> srv : apply(filter, institutions)
    srv --> ui : List<SearchResult> filteredResults
    deactivate srv
    ui --> usr : display filtered list
    deactivate ui
end

@enduml