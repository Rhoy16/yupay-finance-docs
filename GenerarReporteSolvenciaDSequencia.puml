@startuml "Secuencia - Generar Reporte de Solvencia"

autonumber
skinparam BoxPadding 10
skinparam ParticipantPadding 10

' Estilo profesional y limpio
skinparam actorStyle awesome
skinparam sequence {
    LifeLineBorderColor #2B88D9
    LifeLineBackgroundColor #F3F9FF
    ParticipantBorderColor #2B88D9
    ParticipantBackgroundColor #F3F9FF
    BoxBorderColor #2B88D9
    BoxBackgroundColor #F8F9FA
}

actor User as usr
boundary UI_InstitutionDetail as ui
control ReportController as ctrl
participant SolvencyService as srv
database FinancialDatabase as db
entity SolvencyReport as rpt

== Main Flow: Generate Report ==

usr -> ui : Click on "View solvency report"
activate ui

ui -> ctrl : requestReport(institutionId)
activate ctrl

ctrl -> srv : createReport(institutionId)
activate srv

srv -> db : querySolvencyHistory(institutionId)
activate db
db --> srv : rawData (ratios, historical equity)
deactivate db

srv -> srv : processInformation(rawData)
srv -> rpt ** : <<create>> SolvencyReport
srv --> ctrl : report: SolvencyReport
deactivate srv

ctrl --> ui : formattedData
deactivate ctrl

ui --> usr : Renders report on screen
deactivate ui

== Optional Flow: Download PDF ==

opt User requests to download the report
    usr -> ui : Click on "Download PDF"
    activate ui

    ui -> ctrl : requestPdfDownload(institutionId)
    activate ctrl

    ctrl -> srv : exportPdf(report)
    activate srv
    srv --> ctrl : pdfFile: File
    deactivate srv

    ctrl --> ui : pdfFile
    deactivate ctrl

    ui --> usr : Downloads PDF file
    deactivate ui
end

@enduml
